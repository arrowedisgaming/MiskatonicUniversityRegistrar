	"eras": [
		{
			"id": "1920s",
			"name": "1920s Classic",
			"description": "The classic Lovecraftian era of Prohibition-era America and interwar Europe.",
			"currencyUnit": "dollars",
			"currencySymbol": "$"
		},
		{
			"id": "modern",
			"name": "Modern Day",
			"description": "Contemporary investigations using the modern-day tables and era-limited skills.",
			"currencyUnit": "dollars",
			"currencySymbol": "$"
		},
		{
			"id": "gaslight",
			"name": "Gaslight (1880–1899)",
			"description": "The fog-shrouded streets of late-Victorian Britain, 1880–1899. An age of gas lamps and coal-fired engines, of bustles and bowler hats, of consulting detectives and rising spiritualism — where the British Empire stretches across the globe and Jack the Ripper signs his letters 'from hell.' Investigators range from upper-class aristocrats to working-class engineers, all chasing horrors lurking behind the respectable face of the Empire.",
			"currencyUnit": "pounds",
			"currencySymbol": "£"
		}
	],
	"characteristicMethods": [
		{
			"id": "roll",
			"name": "Roll",
			"description": "Roll dice for each characteristic: 3D6×5 for STR/CON/DEX/APP/POW, (2D6+6)×5 for SIZ/INT/EDU."
		},
		{
			"id": "arrange-rolls",
			"name": "Arrange Rolls",
			"description": "Roll the same pools as normal, then place the results among compatible characteristics."
		},
		{
			"id": "point-buy",
			"name": "Point Buy",
			"description": "Assign 460 points among the eight characteristics within the normal starting ranges."
		},
		{
			"id": "quick-fire",
			"name": "Quick Fire",
			"description": "Assign 40, 50, 50, 50, 60, 60, 70, and 80 among the characteristics."
		},
		{
			"id": "low-roll-modifier",
			"name": "Low Roll Modifier",
			"description": "After rolling, add an extra 1D6×5 points among low characteristics."
		},
		{
			"id": "human-potential",
			"name": "Human Potential",
			"description": "After generation, add 1D10 points among characteristics, capped at 99."
		}
	],
