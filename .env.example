# Miskatonic University Registrar — Environment Variables

# Auth (required for production)
AUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:5173
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Database (default: local.db in project root)
DATABASE_URL=local.db

# Build/server
ADAPTER=auto
NODE_ENV=development
ORIGIN=http://localhost:5173
PORT=3000
